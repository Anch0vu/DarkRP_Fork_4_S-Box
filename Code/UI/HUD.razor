@* Source: gamemode/modules/hud/cl_hud.lua *@
@* Lua: hook.Add("HUDPaint", ...) — заменено на Razor компонент *@
@using System;
@using Sandbox;
@using Sandbox.UI;
@using SboxDarkRP;
@inherits PanelComponent

<root>
    @if ( LocalPlayer is not null )
    {
        <div class="hud-root">

            @* ── Деньги / Money ────────────────────────────────────────── *@
            @* Lua: draw.DrawText(DarkRP.formatMoney(ply:getMoney()), ...) *@
            <div class="hud-money">
                <span class="hud-money-icon">💵</span>
                <span class="hud-money-value">@DarkRP.FormatMoney( LocalPlayer.GetMoney() )</span>
            </div>

            @* ── Работа / Job ──────────────────────────────────────────── *@
            @* Lua: draw.DrawText(ply:getJobTable().name, ...) *@
            @{
                var job = LocalPlayer.GetJob();
            }
            @if ( job is not null )
            {
                <div class="hud-job" style="color: @ColorToHex(job.Color)">
                    @job.Name
                </div>
            }

            @* ── Зарплата / Salary ─────────────────────────────────────── *@
            @if ( job is not null && job.Salary > 0 )
            {
                <div class="hud-salary">
                    Зарплата: @DarkRP.FormatMoney( job.Salary )
                </div>
            }

            @* ── Здоровье / Health ─────────────────────────────────────── *@
            @* Lua: hud рисует health bar *@
            <div class="hud-health">
                <div class="hud-health-label">HP</div>
                <div class="hud-health-bar">
                    <div class="hud-health-fill" style="width: @GetHealthPercent()%"></div>
                </div>
            </div>

            @* ── Бронежилет / Armor ─────────────────────────────────────── *@
            <div class="hud-armor">
                <div class="hud-armor-label">AP</div>
                <div class="hud-armor-bar">
                    <div class="hud-armor-fill" style="width: @GetArmorPercent()%"></div>
                </div>
            </div>

            @* ── Статус: арест / розыск ─────────────────────────────────── *@
            @* Lua: if ply:isArrested() then draw "ARRESTED" *@
            @if ( LocalPlayer.IsArrested() )
            {
                var comp = LocalPlayer.GetDarkRPComponent();
                <div class="hud-arrested">
                    АРЕСТОВАН — @( comp is not null ? $"{(int)comp.ArrestTimeRemaining}с" : "" )
                </div>
            }
            else if ( LocalPlayer.IsWanted() )
            {
                var comp = LocalPlayer.GetDarkRPComponent();
                <div class="hud-wanted">
                    РАЗЫСКИВАЕТСЯ — @( comp?.WantedReason ?? "" )
                </div>
            }

            @* ── Повестка мэра / Agenda ─────────────────────────────────── *@
            @* Lua: hook.Add("DarkRPVarChanged", "agendaHUD", ...) *@
            @{
                var comp2 = LocalPlayer.GetDarkRPComponent();
                var agenda = comp2?.Agenda ?? "";
            }
            @if ( !string.IsNullOrWhiteSpace( agenda ) )
            {
                <div class="hud-agenda">
                    <div class="hud-agenda-title">Повестка:</div>
                    <div class="hud-agenda-text">@agenda</div>
                </div>
            }

            @* ── Голод (hungermod) ──────────────────────────────────────── *@
            @* Lua: hook.Add("HUDDrawTargetID", "HMHUD", HMHUD) *@
            @if ( comp2 is not null )
            {
                <div class="hud-hunger">
                    <div class="hud-hunger-label">🍖</div>
                    <div class="hud-hunger-bar">
                        <div class="hud-hunger-fill" style="width: @comp2.Hunger%"></div>
                    </div>
                </div>
            }

        </div>

        @* ── Уведомления / Notifications ─────────────────────────────── *@
        @* Lua: DarkRP.notify → cl_drawfunctions.lua *@
        <div class="hud-notifications">
            @foreach ( var n in NotificationQueue.GetActive() )
            {
                <div class="hud-notify" style="background: @ColorToHex(n.GetColor().WithAlpha(0.8f))">
                    @n.Message
                </div>
            }
        </div>

        @* ── Список печатающих игроков (chatindicator) ───────────────── *@
        @* Lua: gamemode/modules/chatindicator/cl_init.lua — индикатор печати *@
        @{
            var typingPlayers = GetTypingPlayers();
        }
        @if ( typingPlayers.Count > 0 )
        {
            <div class="hud-typing-list">
                @foreach ( var name in typingPlayers )
                {
                    <div class="hud-typing-item">💬 @name печатает...</div>
                }
            </div>
        }

        @* ── Оверлей сна (sleep) ────────────────────────────────────── *@
        @* Lua: gamemode/modules/sleep/sv_sleep.lua — black screen *@
        @{
            var localComp = LocalPlayer.GetDarkRPComponent();
        }
        @if ( localComp is not null && localComp.IsSleeping )
        {
            <div class="hud-sleep-overlay">
                <div class="hud-sleep-text">💤 Zzz...</div>
                <div class="hud-sleep-hint">/wake чтобы проснуться</div>
            </div>
        }

        @* ── Оверлей смерти (deathpov) ──────────────────────────────── *@
        @* Lua: gamemode/modules/deathpov/cl_init.lua *@
        @if ( localComp is not null && localComp.IsDead )
        {
            <div class="hud-death-overlay">
                <div class="hud-death-text">ВЫ МЕРТВЫ</div>
                <div class="hud-death-hint">Ожидайте возрождения...</div>
            </div>
        }

        @* ── Оверлей AFK ─────────────────────────────────────────────── *@
        @if ( localComp is not null && localComp.IsAFK )
        {
            <div class="hud-afk-overlay">
                <div class="hud-afk-text">AFK</div>
                <div class="hud-afk-hint">Двигайтесь или /afk чтобы вернуться</div>
            </div>
        }
    }
</root>

@code {
    private Connection? LocalPlayer => Connection.Local;

    private float GetHealthPercent()
    {
        var ply = LocalPlayer;
        if ( ply is null ) return 0f;
        var max = ply.GetMaxHealth();
        if ( max <= 0f ) return 0f;
        return MathF.Round( ply.GetHealth() / max * 100f );
    }

    private float GetArmorPercent()
    {
        var ply = LocalPlayer;
        if ( ply is null ) return 0f;
        var ac = ply.Pawn?.GetComponent<ArmorComponent>();
        if ( ac is null || ac.MaxArmor <= 0 ) return 0f;
        return MathF.Round( (float)ac.Armor / ac.MaxArmor * 100f );
    }

    /// <summary>
    /// Список ников игроков, у которых [Sync] IsTyping == true (исключая себя).
    /// Lua: gamemode/modules/chatindicator/cl_init.lua
    /// </summary>
    private System.Collections.Generic.List<string> GetTypingPlayers()
    {
        var list = new System.Collections.Generic.List<string>();
        var local = LocalPlayer;
        foreach ( var comp in Game.ActiveScene.GetAllComponents<DarkRPPlayerComponent>() )
        {
            if ( !comp.IsTyping ) continue;
            var owner = comp.Network.Owner;
            if ( owner is null || owner == local ) continue;
            list.Add( owner.DisplayName );
        }
        return list;
    }

    private static string ColorToHex( Color c ) =>
        $"#{(int)(c.r * 255):X2}{(int)(c.g * 255):X2}{(int)(c.b * 255):X2}";
}

<style>
    /* ── Список печатающих игроков ─────────────────────────── */
    .hud-typing-list {
        position: absolute;
        bottom: 280px;
        left: 30px;
        flex-direction: column;
        gap: 2px;
        font-family: Roboto;
        font-size: 13px;
        opacity: 0.85;
    }
    .hud-typing-item {
        background-color: rgba(0, 0, 0, 0.55);
        color: #ffd56b;
        padding: 3px 8px;
        border-radius: 3px;
    }

    /* ── Sleep overlay ─────────────────────────────────────── */
    .hud-sleep-overlay {
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        background-color: rgba(0, 0, 0, 0.85);
        align-items: center;
        justify-content: center;
        flex-direction: column;
        font-family: Roboto;
    }
    .hud-sleep-text {
        font-size: 96px;
        color: #b8c5ff;
        font-weight: bold;
        text-shadow: 0 0 20px rgba(135, 165, 255, 0.6);
    }
    .hud-sleep-hint {
        font-size: 18px;
        color: #888;
        margin-top: 20px;
    }

    /* ── Death overlay ─────────────────────────────────────── */
    .hud-death-overlay {
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        background-color: rgba(80, 0, 0, 0.65);
        align-items: center;
        justify-content: center;
        flex-direction: column;
        font-family: Roboto;
    }
    .hud-death-text {
        font-size: 84px;
        color: #ff3b3b;
        font-weight: bold;
        letter-spacing: 8px;
        text-shadow: 0 0 30px rgba(255, 0, 0, 0.8);
    }
    .hud-death-hint {
        font-size: 18px;
        color: #ffaaaa;
        margin-top: 16px;
    }

    /* ── AFK overlay ───────────────────────────────────────── */
    .hud-afk-overlay {
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        background-color: rgba(40, 40, 40, 0.55);
        align-items: center;
        justify-content: center;
        flex-direction: column;
        font-family: Roboto;
    }
    .hud-afk-text {
        font-size: 120px;
        color: #ffcc00;
        font-weight: bold;
        letter-spacing: 12px;
    }
    .hud-afk-hint {
        font-size: 16px;
        color: #cccccc;
        margin-top: 14px;
    }
</style>
